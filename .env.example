# Cloudflare Tunnel token (from Zero Trust > Networks > Tunnels).
# Copy to .env and fill in. NEVER commit .env.
CF_TUNNEL_TOKEN=paste-your-tunnel-token-here

# ---- Optional: search-index check ("בדיקת אינדקס במנועי חיפוש") ----
# Without this the feature self-skips (the UI checkbox stays disabled); the
# Wayback history check needs no key and always works.
# Uses SerpAPI to run real site:<domain> web-search queries through an official
# API. Sign up at https://serpapi.com/ — free tier is 250 searches/month.
SERPAPI_KEY=
