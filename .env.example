# Cloudflare Tunnel token (from Zero Trust > Networks > Tunnels).
# Copy to .env and fill in. NEVER commit .env.
CF_TUNNEL_TOKEN=paste-your-tunnel-token-here

# ---- Optional: Google index check ("בדיקת אינדקס בגוגל") ----
# Without these the feature self-skips (the UI checkbox stays disabled); the
# Wayback history check needs no key and always works.
# Create a Programmable Search Engine set to "search the entire web" and an API
# key — see the README. Free tier ~100 queries/day.
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Optional alternative search backend (used only if the Google vars are unset).
SERPAPI_KEY=
