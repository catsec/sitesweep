# Cloudflare Tunnel token (from Zero Trust > Networks > Tunnels).
# Copy to .env and fill in. NEVER commit .env.
CF_TUNNEL_TOKEN=paste-your-tunnel-token-here

# ---- Optional: Google index check ("בדיקת אינדקס בגוגל") ----
# Without this the feature self-skips (the UI checkbox stays disabled); the
# Wayback history check needs no key and always works.
# Uses SerpAPI to run real site:<domain> Google queries over the whole web.
# (Google's own Custom Search API dropped whole-web search for new engines in
# 2026, so SerpAPI is the supported provider.) Sign up at https://serpapi.com/
SERPAPI_KEY=
